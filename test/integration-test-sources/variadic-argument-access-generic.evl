// success

let access_at = func(index: u64, T: Type, elems: ...T) -> T => elems[index]

let unused = {
	std.assert(access_at(1,  u8, 10, 20, 30) == 20)

	std.assert(access_at(1, u16, 10, 20, 30) == 20)

	std.assert(access_at(1, u32, 10, 20, 30) == 20)

	std.assert(access_at(1, u64, 10, 20, 30) == 20)
}
