// success

let lib_path = std.comp_env().*.defines.ffi_test_library_path


let ffi_test_add_u64 = std.foreign_function(func(a: u64, b: u64) -> u64, lib_path, "ffi_test_add_u64"[..])

let expected_152 = ffi_test_add_u64(71, 81)

let unused_2 = std.assert(expected_152 == 152)


let ffi_test_add_u8 = std.foreign_function(func(a: u8, b: u8) -> u8, lib_path, "ffi_test_add_u8"[..])

let expected_2 = ffi_test_add_u8(254, 4)

let unused_3 = std.assert(expected_2 == 2)
